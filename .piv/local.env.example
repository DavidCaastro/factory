# PIV/OAC Local Environment — plantilla
# Copiar a .piv/local.env y rellenar, O ejecutar:
#   sh scripts/bootstrap.sh
# para auto-detectar y generar este archivo automáticamente.
#
# Este archivo (.piv/local.env) está en .gitignore — nunca versionar.

# Raíz del repositorio (absoluta, sin trailing slash)
REPO_ROOT=

# Sistema operativo detectado: linux | darwin | windows
OS_TYPE=

# Comando Python válido en este sistema
PYTHON_CMD=python3

# Comando ruff (directo o via python -m ruff)
RUFF_CMD=ruff

# Comando pytest (via python -m pytest)
PYTEST_CMD=python3 -m pytest

# Comando pip-audit (opcional — requerido si compliance_scope != NONE)
# Dejar vacío si no está instalado — los gates emitirán BLOQUEADO_POR_HERRAMIENTA
PIP_AUDIT_CMD=
