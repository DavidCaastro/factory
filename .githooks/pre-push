#!/usr/bin/env bash
# PIV/OAC pre-push hook
# Runs SDK test suite before pushing to origin.
# Blocks the push if tests fail or coverage drops below 80%.
# Skip with: git push --no-verify  (emergency only)

set -euo pipefail

BRANCH=$(git rev-parse --abbrev-ref HEAD)
SDK_DIR="$(git rev-parse --show-toplevel)/sdk"

# Only run on branches that touch the SDK
if [ "$BRANCH" = "agent-configs" ] || echo "$BRANCH" | grep -qE "^(feature|fix)/"; then
    echo "[pre-push] Running SDK test suite (branch: $BRANCH)..."

    if [ ! -d "$SDK_DIR" ]; then
        echo "[pre-push] SKIP: sdk/ directory not found"
        exit 0
    fi

    # Find python in the SDK venv or fall back to system python
    if [ -f "$SDK_DIR/.venv/bin/pytest" ]; then
        PYTEST="$SDK_DIR/.venv/bin/pytest"
    elif [ -f "$SDK_DIR/.venv/Scripts/pytest.exe" ]; then
        PYTEST="$SDK_DIR/.venv/Scripts/pytest.exe"
    elif command -v pytest &>/dev/null; then
        PYTEST="pytest"
    else
        echo "[pre-push] WARN: pytest not found — skipping test gate. Install with: pip install pytest pytest-cov"
        exit 0
    fi

    cd "$SDK_DIR"
    if $PYTEST tests/ --cov=piv_oac --cov-fail-under=80 -q --tb=short 2>&1; then
        echo "[pre-push] PASS: tests green, coverage ≥ 80%"
    else
        echo ""
        echo "[pre-push] BLOCKED: tests failed or coverage below 80%."
        echo "[pre-push] Fix the failures before pushing."
        echo "[pre-push] Emergency bypass: git push --no-verify"
        exit 1
    fi
fi
